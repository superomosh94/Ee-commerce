<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <nav class="navbar">
    <div class="container">
      <h1>My App</h1>
      <ul>
        <li><a href="/">Home</a></li>
        <% if (locals.user) { %>
          <% if (user.role==='admin' ) { %>
            <li><a href="/admin/dashboard" style="font-weight: bold; color: #3498db;">Admin Dashboard</a></li>
            <li><span style="margin-right: 15px;">Admin: <strong>
                  <%= user.username %>
                </strong></span></li>
            <% } else { %>
              <li><a href="/">Shop</a></li>
              <li><a href="/cart">Cart</a></li>
              <li><a href="/orders/latest">Orders</a></li>
              <li><span style="margin-right: 15px;">Welcome, <strong>
                    <%= user.username %>
                  </strong></span></li>
              <% } %>
                <li><a href="/logout" class="btn btn-sm">Logout</a></li>
                <% } else { %>
                  <li><a href="/">Shop</a></li>
                  <li><a href="/login">Login</a></li>
                  <li><a href="/register" class="btn btn-primary">Register</a></li>
                  <% } %>
      </ul>
    </div>
  </nav>